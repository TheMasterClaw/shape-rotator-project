# AgentCoordinationDAO Environment Configuration

# ============================================
# NETWORK CONFIGURATION
# ============================================

# Base Sepolia Testnet (Primary)
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_NETWORK_NAME=Base Sepolia
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org

# ============================================
# CONTRACT ADDRESSES (Base Sepolia)
# ============================================

# Update these after deployment
NEXT_PUBLIC_AGENT_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_TASK_COORDINATOR_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_REPUTATION_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_PAYMENT_SPLITTER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_DAO_GOVERNANCE_ADDRESS=0x0000000000000000000000000000000000000000

# Governance Token Address
NEXT_PUBLIC_GOVERNANCE_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# ============================================
# WALLET CONNECT
# ============================================

# Get from https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your_project_id_here

# ============================================
# IPFS / FILE STORAGE
# ============================================

# Pinata API Keys (for agent metadata)
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key
PINATA_JWT=your_pinata_jwt_token

# Or use NFT.Storage
NFT_STORAGE_API_KEY=your_nft_storage_key

# ============================================
# THE GRAPH (Optional - for advanced queries)
# ============================================

# Subgraph URL
NEXT_PUBLIC_SUBGRAPH_URL=https://api.thegraph.com/subgraphs/name/your-subgraph

# ============================================
# ANALYTICS (Optional)
# ============================================

# Vercel Analytics (auto-enabled on Vercel)
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ============================================
# APP CONFIGURATION
# ============================================

# App Name
NEXT_PUBLIC_APP_NAME=AgentCoordinationDAO
NEXT_PUBLIC_APP_DESCRIPTION=Web3 Infrastructure for Multi-Agent Coordination
NEXT_PUBLIC_APP_URL=https://agent-coordination-dao.vercel.app

# Feature Flags
NEXT_PUBLIC_ENABLE_SIMULATION=true
NEXT_PUBLIC_ENABLE_GOVERNANCE=true
NEXT_PUBLIC_ENABLE_NETWORK_VISUALIZER=true

# ============================================
# CONTRACT DEPLOYMENT (Hardhat)
# ============================================

# Private key for deployment (Base Sepolia testnet only!)
# NEVER commit real private keys - use environment or secure vault
PRIVATE_KEY=your_private_key_here

# Base Sepolia Alchemy/Infura RPC (for deployment)
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/your_api_key

# Etherscan API Key for verification
ETHERSCAN_API_KEY=your_etherscan_api_key

# ============================================
# TESTING
# ============================================

# Enable debug logging
DEBUG=false

# Test mnemonic for Hardhat network
TEST_MNEMONIC="test test test test test test test test test test test junk"

# ============================================
# SECURITY WARNINGS
# ============================================

# NEVER commit .env file to git!
# Copy this file to .env.local and fill in your values

# For production:
# - Use hardware wallet for mainnet deployments
# - Store private keys in secure vault (AWS KMS, HashiCorp Vault, etc.)
# - Use different keys for different environments
# - Rotate keys regularly
